---
// src/pages/calendarios/calendario-cliente.astro
---
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Galatea Estudio — Panel de Contenido</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
    <style>
      :root { 
        --teal: #1B9EAD; 
        --teal-light: #4FBFCC; 
        --dark-bg: rgb(20, 23, 40); 
        --border: rgba(255, 255, 255, 0.1); 
      }
      body { 
        font-family: 'DM Sans', sans-serif; 
        background-color: var(--dark-bg); 
        background-image: linear-gradient(rgba(27, 158, 173, 0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(27, 158, 173, 0.05) 1px, transparent 1px);
        background-size: 50px 50px;
        color: #fff; 
        margin: 0; 
      }
      .header { padding: 1.5rem 2rem; border-bottom: 0.5px solid var(--border); display: flex; justify-content: space-between; align-items: center; background: rgba(44, 44, 44, 0.3); backdrop-filter: blur(20px); }
      .header h1 { font-family: 'Playfair Display', serif; color: var(--teal); font-size: 1.2rem; letter-spacing: 0.15em; text-transform: uppercase; margin: 0; }
      .container { max-width: 1400px; margin: 2rem auto; padding: 0 2rem; }
      
      .btn-new { background: var(--teal); color: white; border: none; padding: 12px 24px; border-radius: 50px; cursor: pointer; font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 2rem; transition: 0.3s; }
      .btn-new:hover { background: var(--teal-light); box-shadow: 0 0 20px rgba(27, 158, 173, 0.4); }

      .days-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 15px; }
      .day-box { background: rgba(255,255,255,0.03); border: 0.5px solid var(--border); border-radius: 16px; padding: 1rem; min-height: 140px; transition: 0.4s; }
      .day-box:hover { border-color: var(--teal); background: rgba(27, 158, 173, 0.08); }
      .day-number { font-size: 1.5rem; font-weight: 300; opacity: 0.3; text-align: right; }
      .idea-tag { font-size: 12px; color: var(--teal); margin-top: 8px; font-weight: 500; border-left: 2px solid var(--teal); padding-left: 6px; }

      .zona-creativa { margin-top: 4rem; background: rgba(255,255,255,0.02); padding: 2rem; border-radius: 24px; border: 0.5px solid var(--border); }
      .zona-creativa h2 { font-family: 'Playfair Display', serif; color: var(--teal); margin-bottom: 1.5rem; }
    </style>
</head>
<body>
    <div class="header">
        <h1>Galatea Estudio</h1>
        <div id="cliente-nombre">Panel Vacunorte</div>
    </div>
    
    <div class="container">
        <button class="btn-new" id="btn-nueva-idea">➕ Nueva Idea</button>
        
        <div style="text-align:center; margin-bottom:2rem;">
            <h3 style="font-family:'Playfair Display'; font-size:2rem; margin:0;">Abril 2026</h3>
        </div>

        <div class="days-grid" id="calendario-grid"></div>

        <div class="zona-creativa">
            <h2>🎨 Zona Creativa</h2>
            <div id="ideas-lista">
                <p style="opacity: 0.5;">Cargando ideas...</p>
            </div>
        </div>
    </div>

    <script>
        import { createClient } from '@supabase/supabase-js';
        
        // Usamos tus credenciales del .env [cite: 1326]
        const supabase = createClient("https://gsxagzjktdovwucbsjho.supabase.co", "sb_publishable_fgcyi7whz-Fmtt1eHXr8mw_WX1lJbOW");

        async function cargar() {
            const grid = document.getElementById('calendario-grid');
            grid.innerHTML = '';
            
            // Traer eventos (Día de la Salud, etc.) [cite: 1363, 1607]
            const { data } = await supabase.from('calendario_maestro').select('*');

            for (let i = 1; i <= 30; i++) {
                const fecha = `2026-04-${String(i).padStart(2, '0')}`;
                const ev = data?.find(e => e.fecha === fecha);
                
                grid.innerHTML += `
                    <div class="day-box">
                        <div class="day-number">${i}</div>
                        ${ev ? `<div class="idea-tag">${ev.conmemoracion}</div>` : ''}
                    </div>`;
            }
        }
        cargar();
    </script>
</body>
</html>