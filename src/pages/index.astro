    </div>

    <script type="module">
      import * as THREE from "https://esm.sh/three@0.160.0";
      import { GLTFLoader } from "https://esm.sh/three@0.160.0/examples/jsm/loaders/GLTFLoader.js";
      import { OrbitControls } from "https://esm.sh/three@0.160.0/examples/jsm/controls/OrbitControls.js";

      const container = document.getElementById('three-container');
      const W = container.clientWidth, H = container.clientHeight;
      const scene = new THREE.Scene();
      scene.background = null;
      const isMobile = window.innerWidth < 900;
      const camera = new THREE.PerspectiveCamera(45, W/H, 0.1, 100);
      camera.position.set(isMobile ? -4 : -3, isMobile ? 3 : 2.5, isMobile ? 7 : 4);
      const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
      renderer.setSize(W, H);
      renderer.outputColorSpace = THREE.SRGBColorSpace;
      renderer.toneMapping = THREE.ACESFilmicToneMapping;
      renderer.toneMappingExposure = 1.2;
      renderer.shadowMap.enabled = true;
      renderer.shadowMap.type = THREE.PCFSoftShadowMap;
      renderer.setClearColor(0x000000, 0);
      container.appendChild(renderer.domElement);

      const controls = new OrbitControls(camera, renderer.domElement);
      controls.enableDamping = true;
      controls.dampingFactor = 0.05;
      controls.target.set(0, 1, 0);
      controls.minPolarAngle = Math.PI/6;
      controls.maxPolarAngle = Math.PI/2.5;
      controls.minAzimuthAngle = -Math.PI/1.2;
      controls.maxAzimuthAngle = Math.PI/32;
      controls.minDistance = isMobile ? 7 : 5.5;
      controls.maxDistance = isMobile ? 7 : 5.5;
      controls.update();

      scene.add(new THREE.AmbientLight(0xffffff, 1.2));
      const d1 = new THREE.DirectionalLight(0xffffff, 0.8);
      d1.position.set(1, 20, 2); d1.castShadow = true;
      d1.shadow.mapSize.width = 2048; d1.shadow.mapSize.height = 2048;
      d1.shadow.camera.near = 0.1; d1.shadow.camera.far = 30;
      d1.shadow.camera.left = -4; d1.shadow.camera.right = 4;
      d1.shadow.camera.top = 4; d1.shadow.camera.bottom = -4;
      d1.shadow.bias = -0.001; scene.add(d1);
      const d2 = new THREE.DirectionalLight(0xf0f5ff, 0.4);
      d2.position.set(-3, 5, -3); scene.add(d2);
      const d3 = new THREE.DirectionalLight(0xffffff, 0.3);
      d3.position.set(0, 3, 5); scene.add(d3);
      const tl = new THREE.PointLight(0x1B9EAD, 0.6, 8);
      tl.position.set(0, 1.5, -1); scene.add(tl);

      const sp = new THREE.Mesh(new THREE.PlaneGeometry(10,10), new THREE.ShadowMaterial({opacity:0.1}));
      sp.rotation.x = -Math.PI/2; sp.position.y = -0.01; sp.receiveShadow = true; scene.add(sp);

      const loader = new GLTFLoader();
      loader.load('/models/stand.glb',
        (gltf) => {
          const model = gltf.scene;
          const box = new THREE.Box3().setFromObject(model);
          const center = box.getCenter(new THREE.Vector3());
          model.position.sub(center); model.position.y = 0;
          scene.add(model);
          model.traverse(c => { if(c.isMesh) { c.castShadow = true; c.receiveShadow = true; }});
          document.getElementById('load-msg').style.display = 'none';
          setTimeout(() => { const h = document.getElementById('hint'); if(h) h.style.opacity = '0'; }, 4000);
        },
        (xhr) => { const m = document.getElementById('load-msg'); if(m) m.textContent = `Cargando... ${xhr.total ? Math.round(xhr.loaded/xhr.total*100) : 0}%`; },
        () => { const m = document.getElementById('load-msg'); if(m) m.style.display = 'none'; }
      );

      const minAz = -Math.PI/1.2, maxAz = Math.PI/32;
      let rotDir = 1, rotSpeed = 0.0015, userInteracting = false, resumeTimeout = null;
      let currentAngle = -Math.PI/4;
      const radius = camera.position.distanceTo(controls.target);

      controls.addEventListener('start', () => { userInteracting = true; if(resumeTimeout) clearTimeout(resumeTimeout); });
      controls.addEventListener('end', () => { resumeTimeout = setTimeout(() => {
        userInteracting = false;
        const offset = new THREE.Vector3(); offset.copy(camera.position).sub(controls.target);
        currentAngle = Math.atan2(offset.x, offset.z);
      }, 2000); });

      function animate() {
        requestAnimationFrame(animate);
        if(!userInteracting) {
          currentAngle += rotSpeed * rotDir;
          if(currentAngle >= maxAz) { currentAngle = maxAz; rotDir = -1; }
          if(currentAngle <= minAz) { currentAngle = minAz; rotDir = 1; }
          const camH = camera.position.y;
          camera.position.x = controls.target.x + radius * Math.sin(currentAngle);
          camera.position.z = controls.target.z + radius * Math.cos(currentAngle);
          camera.position.y = camH; camera.lookAt(controls.target);
        }
        controls.update(); renderer.render(scene, camera);
      }
      animate();

      window.addEventListener('mousemove', (e) => {
        if(userInteracting) return;
        const mouseX = (e.clientX / window.innerWidth - 0.5) * 2;
        const mouseY = (e.clientY / window.innerHeight - 0.5) * 2;
        controls.target.x = mouseX * 0.3;
        controls.target.y = 1 + mouseY * -0.2;
        controls.update();
      });

      window.addEventListener('resize', () => {
        const W2 = container.clientWidth, H2 = container.clientHeight;
        camera.aspect = W2/H2; camera.updateProjectionMatrix(); renderer.setSize(W2, H2);
      });

      const scrollContainer = document.getElementById('scrollContainer');
      const slides = document.querySelectorAll('.section-slide');
      const dots = document.querySelectorAll('.dot');
      const meshes = document.querySelectorAll('.mesh-bg');
      const scrollInd = document.getElementById('scrollInd');
      let currentSlide = 0;

      function goToSlide(index) {
        slides[currentSlide].classList.remove('active');
        dots[currentSlide].classList.remove('active');
        meshes[currentSlide].style.opacity = '0';
        currentSlide = index;
        slides[currentSlide].classList.add('active');
        dots[currentSlide].classList.add('active');
        meshes[currentSlide].style.opacity = '1';
        scrollInd.style.opacity = currentSlide === slides.length - 1 ? '0' : '1';
      }

      window.addEventListener('scroll', () => {
        const scrollTop = window.scrollY;
        const containerTop = scrollContainer.offsetTop;
        const containerH = scrollContainer.offsetHeight - window.innerHeight;
        const progress = Math.max(0, Math.min(1, (scrollTop - containerTop) / containerH));
        const index = Math.min(slides.length - 1, Math.floor(progress * slides.length));
        if(index !== currentSlide) goToSlide(index);
      });

      dots.forEach(dot => {
        dot.addEventListener('click', () => {
          const index = parseInt(dot.dataset.index);
          const containerTop = scrollContainer.offsetTop;
          const containerH = scrollContainer.offsetHeight - window.innerHeight;
          const targetScroll = containerTop + (index / slides.length) * containerH;
          window.scrollTo({ top: targetScroll, behavior: 'smooth' });
        });
      });
    </script>

    <script>
      const hamburger = document.getElementById('hamburger');
      const mobileMenu = document.getElementById('mobileMenu');
      hamburger.addEventListener('click', () => {
        hamburger.classList.toggle('open');
        mobileMenu.classList.toggle('open');
      });
      mobileMenu.querySelectorAll('a').forEach(a => {
        a.addEventListener('click', () => {
          hamburger.classList.remove('open');
          mobileMenu.classList.remove('open');
        });
      });
    </script>

  </body>
</html>