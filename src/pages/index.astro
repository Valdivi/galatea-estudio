          <div class="section-slide" id="slide-2">
            <div class="slide-inner">
              <div class="slide-left">
                <div class="service-num">03 — Digital</div>
                <div class="eyebrow"><div class="eyebrow-dot"></div><span class="eyebrow-txt">Web &amp; Marketing</span></div>
                <h1 class="slide-title">Digitalizamos<br>tu <em>marca</em></h1>
                <p class="slide-sub">Webs · Marketing Digital · Fotografía</p>
                <p class="slide-desc">Diseñamos tu presencia digital con webs rápidas, estrategias de marketing y fotografía profesional que convierten visitas en clientes.</p>
                <div class="cta-row">
                  <button class="btn-primary">Ver proyectos</button>
                  <button class="btn-ghost">Contactar</button>
                </div>
                <div class="stats-row">
                  <div><div class="stat-num">100%</div><div class="stat-lbl">Clientes satisfechos</div></div>
                  <div><div class="stat-num">SEO</div><div class="stat-lbl">Optimizado</div></div>
                  <div><div class="stat-num">360°</div><div class="stat-lbl">Servicio completo</div></div>
                </div>
