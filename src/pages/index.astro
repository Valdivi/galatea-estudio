<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Galatea Estudio — Te enamorarás de tu creación</title>
    <meta name="description" content="Estudio de diseño de espacios, marketing digital y fabricación en resina en Quito, Ecuador." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      :root { --teal: #1B9EAD; --teal-light: #4FBFCC; --teal-pale: rgba(27,158,173,0.08); --pearl: #B8C4C8; --dark: #ffffff; --white: #2c2c2c; --gray: #aaa; }
      html { scroll-behavior: smooth; }
      body { font-family: 'DM Sans', sans-serif; background: var(--white); color: var(--dark); overflow-x: hidden; }

      nav { position: fixed; top: 16px; left: 50%; transform: translateX(-50%); width: calc(100% - 80px); max-width: 1200px; padding: 14px 32px; display: flex; align-items: center; justify-content: space-between; background: rgba(44,44,44,0.5); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); border: 0.5px solid rgba(255,255,255,0.1); border-radius: 50px; box-shadow: 0 4px 16px rgba(0,0,0,0.06); z-index: 100; }
      .logo-wrap { display: flex; align-items: center; gap: 10px; text-decoration: none; }
      .logo-img { height: 36px; width: auto; }
      .nav-links { display: flex; gap: 28px; list-style: none; }
      .nav-links a { font-size: 10px; letter-spacing: 0.14em; color: rgba(255,255,255,0.6); text-transform: uppercase; text-decoration: none; transition: color 0.2s; }
      .nav-links a:hover { color: var(--teal); }
      .nav-cta { padding: 9px 22px; background: var(--teal); color: #fff; font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; border: none; border-radius: 24px; cursor: pointer; transition: background 0.2s; font-family: 'DM Sans', sans-serif; }
      .nav-cta:hover { background: var(--teal-light); }

      .hamburger { display: none; flex-direction: column; justify-content: center; gap: 5px; background: none; border: none; cursor: pointer; padding: 8px; min-width: 36px; min-height: 36px; }
      .hamburger span { display: block; width: 24px; height: 2px; background: #fff; border-radius: 2px; transition: all 0.3s; pointer-events: none; }
      .hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
      .hamburger.open span:nth-child(2) { opacity: 0; }
      .hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

      .mobile-menu { display: none; position: fixed; top: 72px; left: 50%; transform: translateX(-50%); width: calc(100% - 32px); background: rgba(30,30,30,0.98); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); border: 0.5px solid rgba(255,255,255,0.1); border-radius: 20px; padding: 20px 24px; flex-direction: column; gap: 4px; z-index: 999; }
      .mobile-menu.open { display: flex; }
      .mobile-menu a { font-size: 13px; letter-spacing: 0.12em; color: rgba(255,255,255,0.7); text-transform: uppercase; text-decoration: none; padding: 12px 0; border-bottom: 0.5px solid rgba(255,255,255,0.08); }
      .mobile-menu a:last-of-type { border-bottom: none; }
      .mobile-menu .nav-cta { margin-top: 8px; text-align: center; }

      .scroll-container { position: relative; height: 300vh; }
      .sticky-wrap { position: sticky; top: 0; height: 100vh; overflow: hidden; display: flex; align-items: center; }
      .mesh-bg { position: absolute; inset: 0; width: 100%; height: 100%; pointer-events: none; z-index: 0; opacity: 0; transition: opacity 0.8s ease; }
      .mesh-1 { opacity: 1; }
      .sections-wrap { position: relative; width: 100%; height: 100%; z-index: 2; }
      .section-slide { position: absolute; inset: 0; display: flex; align-items: center; padding: 100px 48px 60px; opacity: 0; transition: opacity 0.6s ease; pointer-events: none; }
      .section-slide.active { opacity: 1; pointer-events: all; }
      .slide-inner { display: flex; align-items: center; width: 100%; max-width: 1200px; margin: 0 auto; gap: 40px; position: relative; z-index: 2; }
      .slide-left { flex: 0 0 480px; }
      .service-num { font-size: 11px; letter-spacing: 0.3em; color: var(--teal); text-transform: uppercase; margin-bottom: 16px; display: flex; align-items: center; gap: 12px; }
      .service-num::before { content: ''; display: block; width: 32px; height: 1px; background: var(--teal); }
      .eyebrow { display: inline-flex; align-items: center; gap: 8px; background: var(--teal-pale); border: 0.5px solid rgba(27,158,173,0.25); border-radius: 20px; padding: 5px 14px; margin-bottom: 24px; }
      .eyebrow-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--teal); flex-shrink: 0; }
      .eyebrow-txt { font-size: 10px; letter-spacing: 0.2em; color: var(--teal); text-transform: uppercase; }
      .slide-title { font-family: 'Playfair Display', serif; font-size: 56px; font-weight: 400; line-height: 1.08; letter-spacing: -0.01em; margin-bottom: 12px; color: #fff; }
      .slide-title em { font-style: italic; color: var(--teal); }
      .slide-sub { font-size: 10px; letter-spacing: 0.22em; color: var(--pearl); text-transform: uppercase; margin-bottom: 20px; }
      .slide-desc { font-size: 15px; line-height: 1.8; color: var(--gray); max-width: 380px; margin-bottom: 36px; }
      .cta-row { display: flex; gap: 14px; align-items: center; }
      .btn-primary { padding: 14px 32px; background: var(--teal); color: #fff; font-family: 'DM Sans', sans-serif; font-size: 11px; font-weight: 500; letter-spacing: 0.18em; text-transform: uppercase; border: none; border-radius: 28px; cursor: pointer; transition: all 0.2s; }
      .btn-primary:hover { background: var(--teal-light); transform: translateY(-2px); }
      .btn-ghost { padding: 14px 32px; background: transparent; color: var(--teal); font-family: 'DM Sans', sans-serif; font-size: 11px; font-weight: 500; letter-spacing: 0.18em; text-transform: uppercase; border: 1.5px solid var(--teal); border-radius: 28px; cursor: pointer; transition: all 0.2s; }
      .btn-ghost:hover { background: var(--teal-pale); }
      .slide-right { flex: 1; height: 520px; position: relative; display: flex; align-items: center; justify-content: center; }
      #three-container { width: 100%; height: 100%; cursor: grab; position: absolute; inset: 0; }
      #three-container:active { cursor: grabbing; }
      .canvas-hint { position: absolute; bottom: 12px; left: 50%; transform: translateX(-50%); font-size: 9px; letter-spacing: 0.18em; color: var(--pearl); text-transform: uppercase; white-space: nowrap; pointer-events: none; transition: opacity 1.5s; }
      #load-msg { position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); font-size: 11px; letter-spacing: 0.2em; color: var(--teal); text-transform: uppercase; z-index: 2; }
      .slide-img { width: 100%; height: 100%; object-fit: contain; border-radius: 16px; opacity: 0; transform: translateY(20px); transition: opacity 0.6s ease, transform 0.6s ease; }
      .section-slide.active .slide-img { opacity: 1; transform: translateY(0); }
      .dots { position: fixed; right: 32px; top: 50%; transform: translateY(-50%); display: flex; flex-direction: column; gap: 12px; z-index: 50; }
      .dot { width: 8px; height: 8px; border-radius: 50%; background: var(--pearl); cursor: pointer; transition: all 0.3s; }
      .dot.active { background: var(--teal); transform: scale(1.4); }
      .stats-row { display: flex; gap: 32px; margin-top: 40px; padding-top: 28px; border-top: 0.5px solid rgba(27,158,173,0.15); }
      .stat-num { font-family: 'Playfair Display', serif; font-size: 28px; font-weight: 500; color: var(--teal); line-height: 1; }
      .stat-lbl { font-size: 9px; letter-spacing: 0.18em; color: var(--pearl); text-transform: uppercase; margin-top: 4px; }
      .scroll-ind { position: absolute; bottom: 32px; left: 50%; transform: translateX(-50%); display: flex; flex-direction: column; align-items: center; gap: 8px; z-index: 10; transition: opacity 0.4s; }
      .scroll-ind span { font-size: 9px; letter-spacing: 0.2em; color: var(--pearl); text-transform: uppercase; }
      .scroll-line { width: 1px; height: 40px; background: linear-gradient(to bottom, var(--teal), transparent); animation: scrollAnim 1.5s ease-in-out infinite; }
      @keyframes scrollAnim { 0%, 100% { transform: scaleY(1); opacity: 1; } 50% { transform: scaleY(0.5); opacity: 0.4; } }

      @media (max-width: 900px) {
        nav { width: calc(100% - 32px); top: 8px; padding: 12px 20px; border-radius: 30px; }
        .nav-links { display: none; }
        .nav-cta.desktop-only { display: none; }
        .hamburger { display: flex; }
        .section-slide { padding: 70px 20px 20px; }
        .slide-inner { flex-direction: column; gap: 20px; }
        .slide-left { flex: none; width: 100%; }
        .slide-title { font-size: 34px; }
        .slide-right { width: 100%; height: 380px; min-height: 380px; }
        #three-container { width: 100%; height: 380px; }
        .stats-row { display: none; }
        .slide-desc { font-size: 13px; margin-bottom: 20px; }
        .cta-row { flex-wrap: wrap; gap: 10px; }
        .btn-primary, .btn-ghost { flex: 1; min-width: 140px; text-align: center; padding: 12px 16px; }
        .dots { right: 8px; }
        .scroll-container { height: 400vh; }
      }
    </style>
  </head>
