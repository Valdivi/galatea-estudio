                <div class="stats-row">
                  <div><div class="stat-num">800</div><div class="stat-lbl">Unidades por lote</div></div>
                  <div><div class="stat-num">2</div><div class="stat-lbl">Tipos de resina</div></div>
                  <div><div class="stat-num">3D</div><div class="stat-lbl">Impresión digital</div></div>
